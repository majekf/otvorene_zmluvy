# GovLens Configuration
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────────
# Provider for the chatbot: mock | openai  (default: mock)
# When set to "openai" but OPENAI_API_KEY is absent, falls back to mock with a warning.
LLM_PROVIDER=mock

# OpenAI API key (required when LLM_PROVIDER=openai; ignored otherwise)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model (default: gpt-4.1-nano)
OPENAI_MODEL=gpt-4.1-nano

# OpenAI temperature (default: 0.2)
OPENAI_TEMPERATURE=0.2

# ── Chatbot Feature Flags ────────────────────────────────────────
# Comma-separated optional features: streaming, provenance, cost_tracking,
# observability, redis_history, postgres_history, langchain
CHAT_FEATURE_FLAGS=

# Enable WebSocket streaming (true/false; default: false → single-response mode)
CHAT_STREAMING=false

# Chat history backend: memory | redis  (default: memory)
CHAT_HISTORY_BACKEND=memory

# Context cache backend: memory | redis  (default: memory)
CHAT_CACHE_BACKEND=memory

# Enable provenance/source citations in responses (true/false; default: false)
CHAT_PROVENANCE=false

# Enable per-response token/cost accounting (true/false; default: false)
CHAT_COST_TRACKING=false

# Enable OpenTelemetry span export (true/false; default: false)
CHAT_OBSERVABILITY=false

# Enable debug logging of full prompt/response pairs (true/false; default: false)
CHAT_DEBUG=false

# Max allowed message length from client (default: 2000)
CHAT_MAX_MESSAGE_LENGTH=2000

# ── Server ────────────────────────────────────────────────────────
GOVLENS_HOST=127.0.0.1
GOVLENS_PORT=8000

# ── Data paths ────────────────────────────────────────────────────
# Path to the JSON file loaded into RAM at startup
# GOVLENS_DATA_PATH=data/contracts.json
GOVLENS_DATA_PATH=data/sample_contracts.json

# Directory where scraped PDFs are stored
SCRAPER_PDF_DIR=data/pdfs

# ── Scraper defaults ──────────────────────────────────────────────
SCRAPER_DELAY=0.5
